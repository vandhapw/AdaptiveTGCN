@article{alonge_temporal_nodate,
	title = {Temporal Convolutional Networks for Financial Time Series Forecasting: A Survey},
	abstract = {Financial time series forecasting is a critical task in quantitative finance, enabling informed decision-making in areas such as stock price prediction, risk management, and algorithmic trading. Traditional models often struggle with capturing complex temporal dependencies and nonlinear patterns inherent in financial data. Temporal Convolutional Networks ({TCNs}), a class of deep learning architectures designed for sequential data, have recently gained significant attention due to their ability to model long-range dependencies with efficient training and stable gradients. This survey comprehensively reviews the application of {TCNs} in financial time series forecasting. We explore the architecture and unique features of {TCNs}, including causal convolutions and dilation mechanisms, which allow for flexible receptive fields and effective temporal modeling. The survey discusses recent advances and comparative performance analyses against other sequence models such as recurrent neural networks ({RNNs}) and transformers in various financial forecasting tasks. Additionally, we highlight key challenges, such as handling non-stationarity and noise in financial data, and outline promising directions for future research, including hybrid models and interpretability enhancements. This work serves as a foundational reference for researchers and practitioners aiming to leverage {TCNs} for robust and accurate financial time series forecasting.},
	author = {Alonge, Mayowa and Isreal, Olatunji},
	langid = {english},
	file = {PDF:C\:\\Users\\user\\Zotero\\storage\\LT73R8VB\\Alonge and Isreal - Temporal Convolutional Networks for Financial Time Series Forecasting A Survey.pdf:application/pdf},
}

