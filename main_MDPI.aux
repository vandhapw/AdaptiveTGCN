\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Multivariate indoor air quality sensor stream over a 4-week slice ($\approx 40{,}320$ readings per channel at 1-minute resolution). Panels~(a)--(e) show CO\textsubscript  {2}, VOC, temperature, humidity, and PM\textsubscript  {2.5} dust respectively. For each channel the running signal is overlaid with its mean (dashed) and the 5th--95th percentile interquantile band (shaded). Panel-level summary statistics ($\mu $, $\sigma $, 5\%/95\% quantiles) are annotated in the upper right of each subplot. Faint vertical dotted lines mark week boundaries. Five channels exhibit clearly heterogeneous dynamics: step changes (CO\textsubscript  {2}, VOC), slow diurnal cycles (temperature, humidity), and transient spikes (dust), motivating the sensor-aware design choices in the proposed framework.}}{13}{figure.caption.5}\protected@file@percent }
\newlabel{fig:time_series}{{3}{13}{Multivariate indoor air quality sensor stream over a 4-week slice ($\approx 40{,}320$ readings per channel at 1-minute resolution). Panels~(a)--(e) show CO\textsubscript {2}, VOC, temperature, humidity, and PM\textsubscript {2.5} dust respectively. For each channel the running signal is overlaid with its mean (dashed) and the 5th--95th percentile interquantile band (shaded). Panel-level summary statistics ($\mu $, $\sigma $, 5\%/95\% quantiles) are annotated in the upper right of each subplot. Faint vertical dotted lines mark week boundaries. Five channels exhibit clearly heterogeneous dynamics: step changes (CO\textsubscript {2}, VOC), slow diurnal cycles (temperature, humidity), and transient spikes (dust), motivating the sensor-aware design choices in the proposed framework}{figure.caption.5}{}}
\newlabel{fig:time_series@cref}{{[figure][3][]3}{[1][13][]13}}
