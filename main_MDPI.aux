\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Adaptive Uncertainty-Aware Attention (AUAA) dataflow. Standard scaled dot-product attention (left column) is element-wise modulated by an uncertainty gate $g_t = 1/(1+\boldsymbol  {\sigma }_t)$ derived from MC dropout (right column). Dashed red line indicates the uncertainty feedback path that distinguishes this work from prior uncertainty-aware models, which use $\sigma _t$ only at the output layer.}}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:auaa}{{2}{8}{Adaptive Uncertainty-Aware Attention (AUAA) dataflow. Standard scaled dot-product attention (left column) is element-wise modulated by an uncertainty gate $g_t = 1/(1+\boldsymbol {\sigma }_t)$ derived from MC dropout (right column). Dashed red line indicates the uncertainty feedback path that distinguishes this work from prior uncertainty-aware models, which use $\sigma _t$ only at the output layer}{figure.caption.4}{}}
\newlabel{fig:auaa@cref}{{[figure][2][]2}{[1][8][]8}}
